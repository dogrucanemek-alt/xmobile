{
  "testRunner": "jest",
  "runners": {
    "ios": {
      "type": "ios.simulator",
      "device": {
        "type": "iPhone 15"
      }
    },
    "android": {
      "type": "android.emu",
      "device": {
        "avdName": "Pixel_4_API_30"
      }
    }
  },
  "apps": {
    "ios": {
      "type": "ios.app",
      "binaryPath": "ios/build/xmobile.app",
      "build": "xcodebuild -workspace ios/xmobile.xcworkspace -scheme xmobile -configuration Release -derivedDataPath ios/build"
    },
    "android": {
      "type": "android.apk",
      "binaryPath": "android/app/build/outputs/apk/release/app-release.apk",
      "build": "cd android && ./gradlew assembleRelease assembleAndroidTest -DtestBuildType=release && cd .."
    }
  },
  "testSuite": "default"
}
