{
  "expo": {
    "name": "xmobile — AI Moda Asistanı",
    "slug": "xmobile",
    "version": "1.2.0",
    "orientation": "portrait",
    "description": "Your personal AI fashion assistant. Manage your wardrobe, get daily outfit suggestions powered by AI, and dress smart based on real-time weather. | Kişisel AI moda asistanın. Gardırobunu yönet, her sabah kombin önerisi al, hava durumuna göre stil tavsiyesi al.",
    "icon": "./assets/images/icon.png",
    "scheme": "xmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/10ad1d8f-5e54-4560-9747-2175b63a7e1a",
      "enabled": false,
      "checkAutomatically": "NEVER"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.xmobile.app",
      "buildNumber": "12",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Sesli AI özelliği için mikrofon izni gerekiyor.",
        "NSSpeechRecognitionUsageDescription": "Sesli komut tanımak için konuşma tanıma izni gerekiyor.",
        "NSCameraUsageDescription": "Kıyafet ve profil fotoğrafı çekmek için kamera izni gerekiyor.",
        "NSPhotoLibraryUsageDescription": "Gardırobuna kıyafet ve profil fotoğrafı eklemek için galeri izni gerekiyor.",
        "NSPhotoLibraryAddUsageDescription": "Sanal deneme sonuçlarını fotoğraf galerine kaydetmek için izin gerekiyor.",
        "NSLocationWhenInUseUsageDescription": "Bulunduğun şehrin hava durumuna göre kombin önerisi sunmak için konum izni gerekiyor.",
        "CFBundleLocalizations": ["tr", "en"]
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          { "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults", "NSPrivacyAccessedAPITypeReasons": ["CA92.1"] },
          { "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp", "NSPrivacyAccessedAPITypeReasons": ["C617.1"] },
          { "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime", "NSPrivacyAccessedAPITypeReasons": ["35F9.1"] },
          { "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace", "NSPrivacyAccessedAPITypeReasons": ["E174.1"] }
        ]
      }
    },
    "android": {
      "package": "com.xmobile.app",
      "versionCode": 14,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Bulunduğun şehrin hava durumunu göstermek için konum izni gerekiyor."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Kıyafet fotoğraflarına erişmek için izin gerekiyor.",
          "cameraPermission": "Kıyafet fotoğrafı çekmek için kamera izni gerekiyor."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#00D4FF",
          "androidMode": "default"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0A",
          "dark": {
            "backgroundColor": "#0A0A0A"
          }
        }
      ],
      "@sentry/react-native",
      "expo-updates"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "10ad1d8f-5e54-4560-9747-2175b63a7e1a"
      }
    },
    "owner": "emek35"
  }
}
